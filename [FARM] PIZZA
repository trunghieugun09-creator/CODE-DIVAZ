--// ============ UPDATE DISPLAY ============
local function updateRemainingDisplay()
    if not LimitEnabled or MoneyLimit <= 0 then remainingLabel.Text = "" return end
    local remaining = MoneyLimit - TotalEarned
    if remaining < 0 then remaining = 0 end
    if remaining > 0 then remainingLabel.Text = "Còn thiếu: " .. formatWithComma(remaining)
    else remainingLabel.Text = "✅ Đã đạt hạn mức!" end
end

task.spawn(function()
    while true do
        if Enabled then timerLabel.Text = "⏱ " .. formatTime(TotalTime + (os.time() - StartTime))
        else timerLabel.Text = "⏱ " .. formatTime(TotalTime) end
        totalMoneyLabel.Text = "💎 " .. formatMoney(getBaseMoney())
        incomeLabel.Text = "💰 " .. formatMoney(TotalEarned)
        updateRemainingDisplay()
        task.wait(0.1)
    end
end)

