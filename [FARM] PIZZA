local function getBaseMoney()
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local moneyValue = leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Cash") or leaderstats:FindFirstChild("Dollars") or leaderstats:FindFirstChild("Points") or leaderstats:FindFirstChild("Coin")
        if moneyValue then return moneyValue.Value end
    end
    return 0
end

local function formatMoney(amount)
    if amount >= 1000000 then return string.format("%.1fM", amount / 1000000)
    elseif amount >= 1000 then return string.format("%.0fk", amount / 1000)
    else return tostring(amount) end
end

local function formatWithComma(amount)
    local formatted = tostring(amount)
    local result = ""
    local count = 0
    for i = #formatted, 1, -1 do
        result = formatted:sub(i, i) .. result
        count = count + 1
        if count % 3 == 0 and i > 1 then result = "." .. result end
    end
    return result
end

local function checkMoneyLimit()
    if not LimitEnabled or MoneyLimit <= 0 then return false end
    if TotalEarned >= MoneyLimit then return true end
    return false
end

local function onLimitReached()
    if IsKicked then return end
    IsKicked = true
    
    local currentTotalMoney = getBaseMoney()
    local endTime = os.date("%H:%M:%S")
    local displayName = player.DisplayName
    
    Enabled = false
    IsBusy = false
    IsRestarting = false
    TotalTime = TotalTime + (os.time() - StartTime)
    StartTime = 0
    
    local frame = PlayerGui:FindFirstChild("PIZZA_FARM_GUI")
    if frame then
        local button = frame:FindFirstChild("StartStopButton")
        if button then
            button.Text = "▶ START"
            button.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
            local stroke = button.Parent:FindFirstChild("UIStroke")
            if stroke then stroke.Color = Color3.fromRGB(255, 100, 0) end
        end
        local limitToggle = frame:FindFirstChild("LimitToggle")
        if limitToggle then
            LimitEnabled = false
            limitToggle.Text = "OFF"
            limitToggle.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
        end
    end
    
    pcall(function() 
        Remote:FireServer({["Event"] = "Notification", ["Message"] = "✅ Hoàn thành hạn mức " .. formatWithComma(MoneyLimit) .. "!"}) 
    end)
    
    -- Kick ngay với nội dung
    local kickMessage = displayName .. "|Tong tien: " .. formatWithComma(currentTotalMoney) .. "|Thu nhap: " .. formatWithComma(TotalEarned) .. "|End: " .. endTime
    
    task.wait(0.3)
    
    pcall(function()
        player:Kick(kickMessage)
    end)
end

local function updateEarnedMoney()
    local currentMoney = getBaseMoney()
    local earned = currentMoney - lastKnownMoney
    if earned > 0 then TotalEarned = TotalEarned + earned end
    lastKnownMoney = currentMoney
    if checkMoneyLimit() then onLimitReached() end
end

local function resetMoneyCounter()
    lastKnownMoney = getBaseMoney()
    TotalEarned = 0
end

local function formatTime(seconds)
    local hours = math.floor(seconds / 3600)
    local mins = math.floor((seconds % 3600) / 60)
    local secs = math.floor(seconds % 60)
    return string.format("%02d:%02d:%02d", hours, mins, secs)
end

local function isMaskActivated()
    local char = player.Character
    if not char then return false end
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Tool") and v.Name == "Ski Mask" then return true end
    end
    local head = char:FindFirstChild("Head")
    if head then
        for _, v in pairs(head:GetChildren()) do
            if v:IsA("Accessory") and v.Name:find("Ski") then return true end
        end
    end
    return false
end

local function findPizzaInInventory()
    local char = player.Character
    local backpack = player:FindFirstChild("Backpack")
    if char then
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("Tool") and v.Name == "PizzaJob" then return v, "character" end
        end
    end
    if backpack then
        for _, v in pairs(backpack:GetChildren()) do
            if v:IsA("Tool") and v.Name == "PizzaJob" then return v, "backpack" end
        end
    end
    return nil, nil
end

local function goUnderground()
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return false end
    NoclipOn = true
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then v.CanCollide = false end
    end
    local groundY = hrp.Position.Y
    UndergroundY = groundY - HEAD_OFFSET
    hum.PlatformStand = true
    workspace.Gravity = 0
    hrp.CFrame = CFrame.new(hrp.Position.X, UndergroundY, hrp.Position.Z)
    hrp.Velocity = Vector3.zero
    task.wait(0.3)
    return true
end

local function setupSkiMask()
    if MaskReady then return true end
    local char = player.Character
    if not char then return false end
    if isMaskActivated() then MaskReady = true return true end
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, v in pairs(backpack:GetChildren()) do
            if v:IsA("Tool") and v.Name == "Ski Mask" then
                local hum = char:FindFirstChild("Humanoid")
                if hum then
                    hum:EquipTool(v)
                    task.wait(0.5)
                    pcall(function() v:Activate() end)
                    task.wait(0.3)
                    MaskReady = true
                    return true
                end
            end
        end
    end
    pcall(function()
        local skiMaskTool = workspace.Map.Purchasable.Tool:FindFirstChild("Ski Mask")
        if skiMaskTool then Remote:FireServer({["Event"] = "PurchaseTool", ["Tool"] = skiMaskTool}) end
    end)
    local maskTool = nil
    for i = 1, 15 do
        if backpack then
            for _, v in pairs(backpack:GetChildren()) do
                if v:IsA("Tool") and v.Name == "Ski Mask" then maskTool = v break end
            end
        end
        if maskTool then break end
        task.wait(0.2)
    end
    if not maskTool then return false end
    local hum = char:FindFirstChild("Humanoid")
    if hum then
        hum:EquipTool(maskTool)
        task.wait(0.5)
        pcall(function() maskTool:Activate() end)
        task.wait(0.3)
    end
    MaskReady = true
    return true
end

local function forceEquipPizza()
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return false end
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Tool") and v.Name == "PizzaJob" then return true end
    end
    local pizza, location = findPizzaInInventory()
    if not pizza then return false end
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Tool") and v.Name ~= "Ski Mask" then v.Parent = player:FindFirstChild("Backpack") or player end
    end
    task.wait(0.1)
    hum:EquipTool(pizza)
    task.wait(0.2)
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Tool") and v.Name == "PizzaJob" then return true end
    end
    return false
end

local function getChar()
    local char = player.Character or player.CharacterAdded:Wait()
    local hum = char:WaitForChild("Humanoid")
    local hrp = char:WaitForChild("HumanoidRootPart")
    return char, hum, hrp
end

local function enableNoclip(char)
    NoclipOn = true
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then v.CanCollide = false end
    end
end

local function disableNoclip(char)
    NoclipOn = false
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then v.CanCollide = true end
    end
end

local function enableFreefall(hum)
    hum.PlatformStand = true
    workspace.Gravity = 0
end

local function disableFreefall(hum, hrp)
    hum.PlatformStand = false
    hum.AutoRotate = true
    workspace.Gravity = 196.2
    if hrp then hrp.Velocity = Vector3.zero end
    hum.WalkSpeed = SPEED
end

local function antiStuck(hrp)
    hrp.Velocity = Vector3.new(150, 0, 0) task.wait(0.2)
    hrp.Velocity = Vector3.new(-150, 0, 0) task.wait(0.2)
    hrp.Velocity = Vector3.new(0, 0, 150) task.wait(0.2)
    hrp.Velocity = Vector3.new(0, 0, -150) task.wait(0.2)
    hrp.Velocity = Vector3.zero
end

local function getNewMoney()
    local newMoney = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("MeshPart") and #v.Name > 15 and not CollectedMoneyList[v.Name] then
            table.insert(newMoney, v)
        end
    end
    return newMoney
end

local function collectMoney(money)
    pcall(function()
        Remote:FireServer({["Event"] = "CollectDollar", ["Dollar"] = money})
        CollectedMoneyList[money.Name] = true
    end)
end

local function collectAllNewMoney()
    for _, money in pairs(getNewMoney()) do collectMoney(money) end
end

local function calculateUndergroundY(zoneY)
    return zoneY - HEAD_OFFSET
end

local function flyToTarget(targetPos, hum, hrp)
    local startTime = tick()
    local lastPos = hrp.Position
    local stuckTime = 0
    local isWaiting = false
    local waitStartTime = 0
    local failedAttempts = 0
    local maxFailedAttempts = 3
    
    if not hum.PlatformStand then enableFreefall(hum) end
    if UndergroundY then
        hrp.CFrame = CFrame.new(hrp.Position.X, UndergroundY, hrp.Position.Z)
        hrp.Velocity = Vector3.zero
    end
    
    while Enabled and hrp and hrp.Parent do
        local currentPos = hrp.Position
        local flatCurrent = Vector3.new(currentPos.X, 0, currentPos.Z)
        local flatTarget = Vector3.new(targetPos.X, 0, targetPos.Z)
        local dist = (flatCurrent - flatTarget).Magnitude
        
        if dist <= 1.5 then hrp.Velocity = Vector3.zero return true end
        
        if tick() - startTime > 5 and not isWaiting then
            isWaiting = true
            waitStartTime = tick()
            hrp.Velocity = Vector3.zero
            if hrp and UndergroundY then hrp.CFrame = CFrame.new(hrp.Position.X, UndergroundY, hrp.Position.Z) end
        end
        
        if isWaiting then
            hrp.Velocity = Vector3.zero
            if hrp and UndergroundY then hrp.CFrame = CFrame.new(hrp.Position.X, UndergroundY, hrp.Position.Z) end
            if tick() - waitStartTime >= 2 then
                isWaiting = false
                startTime = tick()
                failedAttempts = failedAttempts + 1
                if failedAttempts >= maxFailedAttempts then hrp.Velocity = Vector3.zero return false end
            end
            task.wait()
            continue
        end
        
        if tick() - startTime > 20 then hrp.Velocity = Vector3.zero return false end
        
        if dist > 200 then
            hrp.CFrame = CFrame.new(targetPos.X, UndergroundY, targetPos.Z)
            hrp.Velocity = Vector3.zero
            startTime = tick()
            task.wait(0.5)
            continue
        end
        
        local direction = (flatTarget - flatCurrent).Unit
        hrp.Velocity = Vector3.new(direction.X * FLY_SPEED, 0, direction.Z * FLY_SPEED)
        
        if math.abs(hrp.Position.Y - UndergroundY) > 0.5 then
            hrp.CFrame = CFrame.new(hrp.Position.X, UndergroundY, hrp.Position.Z)
            hrp.Velocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z)
        end
        
        hum.AutoRotate = false
        if direction.Magnitude > 0.01 then
            hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(hrp.Position.X + direction.X, hrp.Position.Y, hrp.Position.Z + direction.Z))
        end
        
        if (hrp.Position - lastPos).Magnitude < 0.5 then
            stuckTime = stuckTime + 0.1
            if stuckTime >= 2 then antiStuck(hrp) stuckTime = 0 end
        else
            stuckTime = 0
        end
        lastPos = hrp.Position
        task.wait()
    end
    
    hrp.Velocity = Vector3.zero
    return false
end

local function triggerDelivery(prompt, hrp)
    if hrp and hrp.Parent then hrp.Velocity = Vector3.zero end
    pcall(function()
        prompt:InputHoldBegin()
        task.wait(0.15)
        prompt:InputHoldEnd()
    end)
end

local function findDelivery()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.ActionText == "Deliver" then return v end
    end
    return nil
end

local function startJob()
    pcall(function() Remote:FireServer({["Event"] = "StartJob", ["Job"] = "Pizza"}) end)
end

local function completeJobAndForceEquipPizza()
    pcall(function() Remote:FireServer({["Event"] = "CompletedJob", ["Job"] = "Pizza"}) end)
    task.wait(0.05)
    forceEquipPizza()
end

local function isCharacterAlive()
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return false end
    if hum.Health <= 0 then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    if hrp.Position.Y < -200 then return false end
    return true
end

local function restartFarm()
    if not Enabled then return end
    if IsRestarting then return end
    IsRestarting = true
    IsBusy = false
    isEquipping = false
    UndergroundY = -HEAD_OFFSET
    CollectedMoneyList = {}
    MaskReady = false
    local waited = 0
    while Enabled and not isCharacterAlive() and waited < 30 do
        task.wait(0.5)
        waited = waited + 0.5
    end
    if not Enabled then IsRestarting = false return end
    if not isCharacterAlive() then
        Enabled = false
        IsRestarting = false
        local frame = PlayerGui:FindFirstChild("PIZZA_FARM_GUI")
        if frame then
            local button = frame:FindFirstChild("StartStopButton")
            if button then
                button.Text = "▶ START"
                button.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
            end
        end
        return
    end
    goUnderground()
    setupSkiMask()
    IsRestarting = false
    task.spawn(function() pcall(function() farm() end) end)
end

RunService.Heartbeat:Connect(function()
    if not Enabled then return end
    if IsRestarting then return end
    local char = player.Character
    if not char then restartFarm() return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hum and hum.Health <= 0 then restartFarm() return end
    if hrp and hrp.Position.Y < -200 then restartFarm() return end
    if Enabled and hrp and UndergroundY and not IsRestarting then
        if math.abs(hrp.Position.Y - UndergroundY) > 2 then
            hrp.CFrame = CFrame.new(hrp.Position.X, UndergroundY, hrp.Position.Z)
            hrp.Velocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z)
        end
    end
    if hum and not hum.PlatformStand then
        if hum.WalkSpeed ~= SPEED then hum.WalkSpeed = SPEED end
    end
    if NoclipOn and char then enableNoclip(char) end
    if Enabled and not isEquipping and not IsRestarting then
        if char then
            local hasPizza = false
            for _, v in pairs(char:GetChildren()) do
                if v:IsA("Tool") and v.Name == "PizzaJob" then hasPizza = true break end
            end
            if not hasPizza then task.spawn(function() forceEquipPizza() end) end
        end
    end
end)

player.CharacterAdded:Connect(function(char)
    task.wait(1)
    if Enabled and not IsRestarting then
        CollectedMoneyList = {}
        UndergroundY = -HEAD_OFFSET
        IsBusy = false
        isEquipping = false
        MaskReady = false
        task.spawn(function()
            pcall(function()
                goUnderground()
                setupSkiMask()
                farm()
            end)
        end)
    end
end)

function farm()
    while Enabled do
        if IsRestarting then task.wait(0.5) continue end
        if IsBusy then task.wait(0.3) continue end
        IsBusy = true
        if not isCharacterAlive() then IsBusy = false restartFarm() continue end
        if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            task.wait(1) IsBusy = false continue
        end
        forceEquipPizza()
        startJob()
        local prompt = nil
        local findStart = tick()
        repeat
            if not Enabled or IsRestarting then IsBusy = false return end
            if not isCharacterAlive() then IsBusy = false restartFarm() return end
            prompt = findDelivery()
            if prompt then break end
            task.wait(0.2)
        until tick() - findStart > 5
        if not prompt then IsBusy = false task.wait(0.5) continue end
        local char, hum, hrp = getChar()
        if not char or not hum or not hrp then IsBusy = false task.wait(1) continue end
        if not isCharacterAlive() then IsBusy = false restartFarm() continue end
        local targetPos = prompt.Parent.Position
        UndergroundY = calculateUndergroundY(targetPos.Y)
        enableNoclip(char)
        enableFreefall(hum)
        hrp.CFrame = CFrame.new(hrp.Position.X, UndergroundY, hrp.Position.Z)
        hrp.Velocity = Vector3.zero
        local reached = flyToTarget(targetPos, hum, hrp)
        if not isCharacterAlive() then IsBusy = false restartFarm() continue end
        if not reached then
            IsBusy = false
            pcall(function() Remote:FireServer({["Event"] = "CompletedJob", ["Job"] = "Pizza"}) end)
            task.wait(0.5) forceEquipPizza() task.wait(0.5) continue
        end
        if Enabled and player.Character and hrp and hrp.Parent and isCharacterAlive() then
            triggerDelivery(prompt, hrp)
            task.wait(0.3)
            for i = 1, 3 do
                if not Enabled or IsRestarting then break end
                if not isCharacterAlive() then break end
                completeJobAndForceEquipPizza()
                task.wait(0.2)
                local newMoney = getNewMoney()
                if #newMoney > 0 then
                    for _, money in pairs(newMoney) do collectMoney(money) end
                    break
                end
            end
            if Enabled and not IsRestarting and isCharacterAlive() then
                startJob()
                forceEquipPizza()
            end
            collectAllNewMoney()
            updateEarnedMoney()
            task.wait(0.3)
        end
        IsBusy = false
        task.wait(0.1)
    end
end

local function startFarm()
    if not Enabled then return end
    goUnderground()
    setupSkiMask()
    farm()
end

