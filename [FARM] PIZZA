inputBox:GetPropertyChangedSignal("Text"):Connect(function()
    local raw = string.gsub(inputBox.Text, "%.", "")
    raw = string.gsub(raw, "[^%d]", "")
    if raw == "" then inputBox.Text = "" return end
    local num = tonumber(raw)
    if num then
        local formatted = formatWithComma(num)
        inputBox.Text = formatted
        pcall(function() inputBox.CursorPosition = #formatted end)
    end
end)

