limitToggle.MouseButton1Click:Connect(function()
    LimitEnabled = not LimitEnabled
    if LimitEnabled then
        limitToggle.Text = "ON"
        limitToggle.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        if MoneyLimit > 0 then
            local remaining = MoneyLimit - TotalEarned
            if remaining < 0 then remaining = 0 end
            limitLabel.Text = "Hạn mức: " .. formatWithComma(MoneyLimit) .. " ✓"
            if remaining > 0 then remainingLabel.Text = "Còn thiếu: " .. formatWithComma(remaining)
            else remainingLabel.Text = "✅ Đã đạt hạn mức!" end
        else
            limitLabel.Text = "Hạn mức: ON (chưa đặt)"
            remainingLabel.Text = "⚠️ Chưa đặt hạn mức"
        end
    else
        limitToggle.Text = "OFF"
        limitToggle.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
        remainingLabel.Text = ""
        if MoneyLimit > 0 then limitLabel.Text = "Hạn mức: " .. formatWithComma(MoneyLimit)
        else limitLabel.Text = "Hạn mức: OFF" end
    end
end)

