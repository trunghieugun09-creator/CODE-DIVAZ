-- Tao nut
local function taoNut(text, mau, callback)
    local btn = Instance.new("TextButton", body)
    btn.Size = UDim2.new(1, -16, 0, 32)
    btn.BackgroundColor3 = mau
    btn.Text = text
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 10
    btn.AutoButtonColor = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

local function taoToggle(text, mauOn, mauOff, callback)
    local on = false
    local btn = Instance.new("TextButton", body)
    btn.Size = UDim2.new(1, -16, 0, 32)
    btn.BackgroundColor3 = mauOff
    btn.Text = text .. ": OFF"
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 10
    btn.AutoButtonColor = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(function()
        on = not on
        btn.Text = text .. (on and ": ON" or ": OFF")
        btn.BackgroundColor3 = on and mauOn or mauOff
        callback(on)
    end)
    return btn
end

