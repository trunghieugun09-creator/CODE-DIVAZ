local dang_keo, du_lieu_keo, diem_bat_dau, vi_tri_bat_dau = false, nil, nil, nil
khung_chinh.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        dang_keo = true
        diem_bat_dau = input.Position
        vi_tri_bat_dau = khung_chinh.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dang_keo = false end
        end)
    end
end)
khung_chinh.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
        du_lieu_keo = input
    end
end)
UIS.InputChanged:Connect(function(input)
    if input == du_lieu_keo and dang_keo then
        local delta = input.Position - diem_bat_dau
        khung_chinh.Position = UDim2.new(vi_tri_bat_dau.X.Scale, vi_tri_bat_dau.X.Offset + delta.X, vi_tri_bat_dau.Y.Scale, vi_tri_bat_dau.Y.Offset + delta.Y)
    end
end)
