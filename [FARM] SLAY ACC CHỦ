local function cap_nhat_danh_sach()
    for _, v in pairs(khung_cuon:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end
    for _, pl in pairs(Players:GetPlayers()) do
        if pl ~= nguoi_choi then
            local b = Instance.new("TextButton", khung_cuon)
            b.Size = UDim2.new(1, -6, 0, 24)
            b.BackgroundColor3 = (muc_tieu == pl) and Color3.fromRGB(120, 0, 150) or Color3.fromRGB(35, 35, 40)
            b.Text = "  " .. pl.Name
            b.TextColor3 = Color3.new(1, 1, 1)
            b.Font = Enum.Font.Gotham
            b.TextSize = 11
            b.TextXAlignment = Enum.TextXAlignment.Left
            Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
            local ref = pl
            b.MouseButton1Click:Connect(function()
                muc_tieu = ref
                cap_nhat_danh_sach()
            end)
        end
    end
    khung_cuon.CanvasSize = UDim2.new(0, 0, 0, danh_sach.AbsoluteContentSize.Y + 5)
end

Players.PlayerAdded:Connect(cap_nhat_danh_sach)
Players.PlayerRemoving:Connect(function(pl)
    if muc_tieu == pl then muc_tieu = nil end
    cap_nhat_danh_sach()
end)
cap_nhat_danh_sach()

