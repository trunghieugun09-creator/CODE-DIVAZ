local function bam_phim(key)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, key, false, game)
        task.wait(0.01)
        VirtualInputManager:SendKeyEvent(false, key, false, game)
    end)
end

local function lay_nhan_vat()
    local c = nguoi_choi.Character
    if not c then return nil, nil, nil end
    return c, c:FindFirstChild("Humanoid"), c:FindFirstChild("HumanoidRootPart")
end

local function lay_tool_uu_tien()
    local c = nguoi_choi.Character
    local bp = nguoi_choi:FindFirstChild("Backpack")
    if c then
        for _, v in pairs(c:GetChildren()) do
            if v:IsA("Tool") and string.find(string.lower(v.Name), "nails") then return v end
        end
    end
    if bp then
        for _, v in pairs(bp:GetChildren()) do
            if v:IsA("Tool") and string.find(string.lower(v.Name), "nails") then return v end
        end
    end
    if c then
        for _, v in pairs(c:GetChildren()) do
            if v:IsA("Tool") and v.Name == "Fist" then return v end
        end
    end
    if bp then
        local fist = bp:FindFirstChild("Fist")
        if fist then return fist end
    end
    return nil
end

local function trang_bi_vu_khi()
    local c = nguoi_choi.Character
    if not c then return false end
    local h = c:FindFirstChild("Humanoid")
    if not h then return false end
    local tool_hien_tai = lay_tool_uu_tien()
    if tool_hien_tai and tool_hien_tai.Parent == c then return true end
    if tool_hien_tai and tool_hien_tai.Parent ~= c then
        h:EquipTool(tool_hien_tai)
        task.wait(0.02)
        return true
    end
    return false
end

local function danh()
    trang_bi_vu_khi()
    local c = nguoi_choi.Character
    if c then
        local tool = lay_tool_uu_tien()
        if tool and tool:IsA("Tool") then pcall(function() tool:Activate() end) end
    end
end

local function tom() bam_phim(Enum.KeyCode.G) end

local function stomp()
    bam_phim(Enum.KeyCode.E)
    danh()
end

local function dung_di_chuyen()
    dang_di_chuyen = false
    if tac_vu_di_chuyen then task.cancel(tac_vu_di_chuyen); tac_vu_di_chuyen = nil end
end

local function di_toi_muc_tieu(dich)
    if tac_vu_di_chuyen then task.cancel(tac_vu_di_chuyen) end
    dang_di_chuyen = true
    tac_vu_di_chuyen = task.spawn(function()
        local _, h, r = lay_nhan_vat()
        if not h or not r then dang_di_chuyen = false return end
        h.WalkSpeed = toc_do_chay
        while dang_hoat_dong and dang_di_chuyen and r and r.Parent and dich and dich.Parent do
            if not muc_tieu or not muc_tieu.Character then break end
            local dich2 = muc_tieu.Character:FindFirstChild("HumanoidRootPart")
            if not dich2 then break end
            local khoang_cach = (r.Position - dich2.Position).Magnitude
            if khoang_cach <= tam_danh then break end
            r.CFrame = CFrame.lookAt(r.Position, Vector3.new(dich2.Position.X, r.Position.Y, dich2.Position.Z))
            h:MoveTo(dich2.Position)
            task.wait(0.05)
        end
        dang_di_chuyen = false
        tac_vu_di_chuyen = nil
    end)
end

local function lui_ra(dich, muc_tieu_khoang_cach)
    if tac_vu_di_chuyen then task.cancel(tac_vu_di_chuyen) end
    dang_di_chuyen = true
    tac_vu_di_chuyen = task.spawn(function()
        local _, h, r = lay_nhan_vat()
        if not h or not r then dang_di_chuyen = false return end
        h.WalkSpeed = toc_do_chay
        local huong_lui = (r.Position - dich.Position).Unit
        if huong_lui.Magnitude < 0.01 then huong_lui = Vector3.new(0, 0, -1) end
        local vi_tri_lui = r.Position + huong_lui * muc_tieu_khoang_cach
        while dang_hoat_dong and dang_di_chuyen and r and r.Parent do
            local khoang_cach = (r.Position - vi_tri_lui).Magnitude
            if khoang_cach <= 0.5 then break end
            h:MoveTo(vi_tri_lui)
            task.wait(0.05)
        end
        dang_di_chuyen = false
        tac_vu_di_chuyen = nil
    end)
end

task.spawn(function()
    while true do
        task.wait(0.03)
        if not dang_hoat_dong then dung_di_chuyen(); dang_danh = false; continue end
        if not muc_tieu then dung_di_chuyen(); dang_danh = false; continue end
        local tc = muc_tieu.Character
        if not tc then dung_di_chuyen(); dang_danh = false; continue end
        local dich = tc:FindFirstChild("HumanoidRootPart")
        local mau_dich = tc:FindFirstChild("Humanoid")
        if not dich or not mau_dich or mau_dich.Health <= 0 then dung_di_chuyen(); dang_danh = false; continue end
        local _, _, r = lay_nhan_vat()
        if not r then dang_danh = false; continue end
        local khoang_cach = (r.Position - dich.Position).Magnitude
        if mau_dich.Health < nguong_mau then
            if khoang_cach > tam_danh then dang_danh = true; if not dang_di_chuyen then di_toi_muc_tieu(dich) end
            elseif khoang_cach < 1 then dang_danh = true; if not dang_di_chuyen then lui_ra(dich, tam_lui) end
            else dung_di_chuyen(); dang_danh = true; r.CFrame = CFrame.lookAt(r.Position, Vector3.new(dich.Position.X, r.Position.Y, dich.Position.Z)); stomp(); task.wait(0.02) end
        else
            if khoang_cach > tam_danh then dang_danh = true; if not dang_di_chuyen then di_toi_muc_tieu(dich) end
            elseif khoang_cach < 1 then dang_danh = true; if not dang_di_chuyen then lui_ra(dich, tam_lui) end
            else dung_di_chuyen(); dang_danh = true; r.CFrame = CFrame.lookAt(r.Position, Vector3.new(dich.Position.X, r.Position.Y, dich.Position.Z)); danh(); tom(); task.wait(0.02) end
        end
    end
end)

